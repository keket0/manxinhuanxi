# 基础路径
WEATHER_WORKSPACE=/path/to/weather-push-replica
WEATHER_OUTPUT_DIR=/tmp/weather-output
WEATHER_PYTHON_BIN=/path/to/weather-push-replica/.venv/bin/python

# 发送配置
WEATHER_SENDER_MODE=openclaw
WEATHER_CHANNEL=telegram
WEATHER_ACCOUNT_ID=agner
WEATHER_TARGET=1747307647

# 城市配置（默认枣庄）
WEATHER_WTTR_QUERY=枣庄
WEATHER_TARGET_CITY=枣庄地区
WEATHER_TARGET_LAT=34.81071
WEATHER_TARGET_LON=117.32373
WEATHER_TARGET_TZ=Asia/Shanghai
WEATHER_OPEN_METEO_GEOCODE=https://geocoding-api.open-meteo.com/v1/search?name=%E6%9E%A3%E5%BA%84%E5%B8%82&count=5&language=zh&format=json

# 资源目录（通常不用改）
WEATHER_ICONS_DIR=/path/to/weather-push-replica/assets/icons-legacy
WEATHER_SYMBOLS_DIR=/path/to/weather-push-replica/assets/twemoji-weather

# fallback 可选
WEATHER_TIMEZONE=Asia/Shanghai
WEATHER_MAIN_RUNS_JSONL=/path/to/main-job-runs.jsonl
